<?xml version="1.0" encoding="UTF-8"?>
<!-- pain.001.001.03 — CustomerCreditTransferInitiation (ISO 20022 / EPC SEPA SCT 2009) -->
<!-- SAP ERP legacy standard. Key traits: BICOrBEI in OrgId, BIC (not BICFI) in         -->
<!-- FinInstnId, unstructured AdrLine only, no UETR, no LEI, ReqdExctnDt plain date,    -->
<!-- ChrgBr at PmtInf or CdtTrfTxInf level, BtchBookg supported.                        -->
<Document xmlns="urn:iso:std:iso:20022:tech:xsd:pain.001.001.03"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="urn:iso:std:iso:20022:tech:xsd:pain.001.001.03 pain.001.001.03.xsd">
  <CstmrCdtTrfInitn>
    <GrpHdr>
      <MsgId>MSGID-20260413-03-001</MsgId>
      <CreDtTm>2026-04-13T10:00:00</CreDtTm>
      <NbOfTxs>1</NbOfTxs>
      <CtrlSum>100.00</CtrlSum>
      <InitgPty>
        <Nm>Test Debtor GmbH</Nm>
        <PstlAdr>
          <!-- .03: unstructured AdrLine only — no StrtNm/BldgNb/PstCd separate fields -->
          <Ctry>DE</Ctry>
          <AdrLine>Teststraße 1</AdrLine>
          <AdrLine>90401 Nürnberg</AdrLine>
        </PstlAdr>
        <Id>
          <OrgId>
            <!-- .03: BICOrBEI for org identification — LEI not yet in schema -->
            <BICOrBEI>COBADEFFXXX</BICOrBEI>
          </OrgId>
        </Id>
      </InitgPty>
    </GrpHdr>
    <PmtInf>
      <PmtInfId>PMTINF-20260413-03-001</PmtInfId>
      <PmtMtd>TRF</PmtMtd>
      <!-- BtchBookg: true = single batch booking, false = per-transaction -->
      <BtchBookg>false</BtchBookg>
      <NbOfTxs>1</NbOfTxs>
      <CtrlSum>100.00</CtrlSum>
      <PmtTpInf>
        <!-- InstrPrty: NORM (normal) or HIGH (priority) -->
        <InstrPrty>NORM</InstrPrty>
        <SvcLvl>
          <Cd>SEPA</Cd>
        </SvcLvl>
        <CtgyPurp>
          <Cd>SUPP</Cd>
        </CtgyPurp>
      </PmtTpInf>
      <!-- .03: ReqdExctnDt is a plain xs:date string (not a complex element) -->
      <ReqdExctnDt>2026-04-14</ReqdExctnDt>
      <Dbtr>
        <Nm>Test Debtor GmbH</Nm>
        <!-- .03: only AdrLine supported, no StrtNm/BldgNb/PstCd as separate elements -->
        <PstlAdr>
          <Ctry>DE</Ctry>
          <AdrLine>Teststraße 1</AdrLine>
          <AdrLine>90401 Nürnberg</AdrLine>
        </PstlAdr>
        <Id>
          <OrgId>
            <BICOrBEI>COBADEFFXXX</BICOrBEI>
          </OrgId>
        </Id>
      </Dbtr>
      <DbtrAcct>
        <Id>
          <IBAN>DE89370400440532013000</IBAN>
        </Id>
        <Ccy>EUR</Ccy>
        <Nm>Hauptkonto</Nm>
      </DbtrAcct>
      <DbtrAgt>
        <FinInstnId>
          <!-- .03: BIC element, not BICFI — BIC is the .03 field name -->
          <BIC>COBADEFFXXX</BIC>
          <Nm>Commerzbank AG</Nm>
          <PstlAdr>
            <Ctry>DE</Ctry>
            <AdrLine>Kaiserplatz 1</AdrLine>
            <AdrLine>60311 Frankfurt am Main</AdrLine>
          </PstlAdr>
        </FinInstnId>
      </DbtrAgt>
      <!-- ChrgBr at PmtInf level valid in .03 -->
      <ChrgBr>SLEV</ChrgBr>
      <CdtTrfTxInf>
        <PmtId>
          <InstrId>INSTRID-03-001</InstrId>
          <!-- .03: no UETR field in schema -->
          <EndToEndId>E2EID-20260413-03-001</EndToEndId>
        </PmtId>
        <Amt>
          <InstdAmt Ccy="EUR">100.00</InstdAmt>
        </Amt>
        <!-- UltmtDbtr: Payment on Behalf Of (POBO) originator -->
        <UltmtDbtr>
          <Nm>Ultimate Debtor Parent AG</Nm>
          <Id>
            <OrgId>
              <Othr>
                <Id>DE-PARENT-001</Id>
              </Othr>
            </OrgId>
          </Id>
        </UltmtDbtr>
        <CdtrAgt>
          <FinInstnId>
            <!-- .03: BIC not BICFI -->
            <BIC>DEUTDEDBXXX</BIC>
            <Nm>Deutsche Bank AG</Nm>
            <PstlAdr>
              <Ctry>DE</Ctry>
              <AdrLine>Taunusanlage 12</AdrLine>
              <AdrLine>60325 Frankfurt am Main</AdrLine>
            </PstlAdr>
          </FinInstnId>
        </CdtrAgt>
        <Cdtr>
          <Nm>Test Creditor AG</Nm>
          <!-- .03: plain AdrLine only -->
          <PstlAdr>
            <Ctry>DE</Ctry>
            <AdrLine>Empfängerstraße 5</AdrLine>
            <AdrLine>10115 Berlin</AdrLine>
          </PstlAdr>
          <Id>
            <OrgId>
              <Othr>
                <Id>HRB-123456-B</Id>
                <SchmeNm>
                  <Cd>COID</Cd>
                </SchmeNm>
              </Othr>
            </OrgId>
          </Id>
        </Cdtr>
        <CdtrAcct>
          <Id>
            <IBAN>DE75512108001245126199</IBAN>
          </Id>
          <Nm>Hauptkonto Creditor</Nm>
        </CdtrAcct>
        <!-- UltmtCdtr: Payment to Behalf Of (PtBO) beneficiary -->
        <UltmtCdtr>
          <Nm>Ultimate Creditor Tochter GmbH</Nm>
        </UltmtCdtr>
        <Purp>
          <Cd>SUPP</Cd>
        </Purp>
        <RmtInf>
          <!-- .03: typically Ustrd (unstructured) remittance info -->
          <!-- Strd also allowed in .03 but Ustrd is the SEPA standard -->
          <Ustrd>Rechnung RE-2026-001 vom 2026-04-01 - Warenlieferung Q1/2026</Ustrd>
        </RmtInf>
      </CdtTrfTxInf>
    </PmtInf>
  </CstmrCdtTrfInitn>
</Document>
