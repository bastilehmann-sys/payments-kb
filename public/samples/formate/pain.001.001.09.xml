<?xml version="1.0" encoding="UTF-8"?>
<!-- pain.001.001.09 — Credit Transfer Initiation (ISO 20022 / EPC SEPA SCT 2019/2023) -->
<!-- The MAJOR migration from .03: structured address (PostalAddress24) already present  -->
<!-- in .09 schema. Key additions vs .03: BICFI, LEI, UETR, structured PostalAddress,   -->
<!-- ReqdExctnDt as complex element, SupplementaryData, UltimateOriginator for POBO.    -->
<Document xmlns="urn:iso:std:iso:20022:tech:xsd:pain.001.001.09"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="urn:iso:std:iso:20022:tech:xsd:pain.001.001.09 pain.001.001.09.xsd">
  <CstmrCdtTrfInitn>
    <GrpHdr>
      <MsgId>MSGID-20260413-09-001</MsgId>
      <CreDtTm>2026-04-13T10:00:00</CreDtTm>
      <NbOfTxs>1</NbOfTxs>
      <CtrlSum>5000.00</CtrlSum>
      <InitgPty>
        <Nm>Test Debtor GmbH</Nm>
        <!-- .09+: LEI replaces BICOrBEI in OrgId -->
        <Id>
          <OrgId>
            <LEI>5493001KJTIIGC8Y1R12</LEI>
          </OrgId>
        </Id>
      </InitgPty>
    </GrpHdr>
    <PmtInf>
      <PmtInfId>PMTINF-20260413-09-001</PmtInfId>
      <PmtMtd>TRF</PmtMtd>
      <NbOfTxs>1</NbOfTxs>
      <CtrlSum>5000.00</CtrlSum>
      <PmtTpInf>
        <SvcLvl>
          <Cd>SEPA</Cd>
        </SvcLvl>
      </PmtTpInf>
      <!-- .09+: ReqdExctnDt becomes a complex element with <Dt> child -->
      <ReqdExctnDt>
        <Dt>2026-04-14</Dt>
      </ReqdExctnDt>
      <!-- .09+: UltimateOriginator for POBO (Payment on Behalf Of) scenarios -->
      <UltmtDbtr>
        <Nm>Ultimate Debtor Parent AG</Nm>
        <Id>
          <OrgId>
            <LEI>3358001KJTIIGC8Y1R99</LEI>
          </OrgId>
        </Id>
      </UltmtDbtr>
      <Dbtr>
        <Nm>Test Debtor GmbH</Nm>
        <!-- .09: PostalAddress24 — structured address already available in .09 schema -->
        <!-- All fields (StrtNm, BldgNb, BldgNm, Flr, PstBx, Room, PstCd, TwnNm,    -->
        <!-- TwnLctnNm, DstrctNm, CtrySubDvsn, Ctry) present in .09.                 -->
        <!-- AdrLine may also be used as fallback alongside structured fields.         -->
        <PstlAdr>
          <StrtNm>Teststraße</StrtNm>
          <BldgNb>1</BldgNb>
          <PstCd>90401</PstCd>
          <TwnNm>Nürnberg</TwnNm>
          <Ctry>DE</Ctry>
        </PstlAdr>
        <Id>
          <OrgId>
            <LEI>5493001KJTIIGC8Y1R12</LEI>
          </OrgId>
        </Id>
      </Dbtr>
      <DbtrAcct>
        <Id>
          <IBAN>DE89370400440532013000</IBAN>
        </Id>
        <Ccy>EUR</Ccy>
      </DbtrAcct>
      <DbtrAgt>
        <FinInstnId>
          <!-- .09+: BICFI replaces BIC -->
          <BICFI>COBADEFFXXX</BICFI>
        </FinInstnId>
      </DbtrAgt>
      <CdtTrfTxInf>
        <PmtId>
          <InstrId>INSTRID-09-001</InstrId>
          <EndToEndId>E2EID-20260413-09-001</EndToEndId>
          <!-- .09+: UETR for end-to-end tracking (UUID format) -->
          <UETR>a1b2c3d4-e5f6-7890-abcd-ef1234567890</UETR>
        </PmtId>
        <Amt>
          <InstdAmt Ccy="EUR">5000.00</InstdAmt>
        </Amt>
        <ChrgBr>SLEV</ChrgBr>
        <CdtrAgt>
          <FinInstnId>
            <BICFI>DEUTDEDBXXX</BICFI>
          </FinInstnId>
        </CdtrAgt>
        <Cdtr>
          <Nm>Test Creditor AG</Nm>
          <!-- .09: full structured address available (PostalAddress24) -->
          <PstlAdr>
            <StrtNm>Empfängerstraße</StrtNm>
            <BldgNb>5</BldgNb>
            <PstCd>10115</PstCd>
            <TwnNm>Berlin</TwnNm>
            <Ctry>DE</Ctry>
          </PstlAdr>
        </Cdtr>
        <CdtrAcct>
          <Id>
            <IBAN>DE75512108001245126199</IBAN>
          </Id>
        </CdtrAcct>
        <Purp>
          <Cd>SUPP</Cd>
        </Purp>
        <!-- .09+: Strd (structured) remittance info with CdtrRefInf -->
        <RmtInf>
          <Strd>
            <CdtrRefInf>
              <Tp>
                <CdOrPrtry>
                  <Cd>SCOR</Cd>
                </CdOrPrtry>
              </Tp>
              <Ref>INV2026-09-001</Ref>
            </CdtrRefInf>
          </Strd>
        </RmtInf>
      </CdtTrfTxInf>
    </PmtInf>
    <!-- .09+: SupplementaryData block for bank-specific extensions -->
    <SplmtryData>
      <Envlp>
        <Nmspc>
          <Id>BankExt</Id>
        </Nmspc>
      </Envlp>
    </SplmtryData>
  </CstmrCdtTrfInitn>
</Document>
